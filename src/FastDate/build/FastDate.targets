<Project>
    <Target Name="CopyNativeLibraries" AfterTargets="Build">
        <ItemGroup>
            <NativeFiles Include="$(MSBuildProjectDirectory)\runtimes\**\*"
                         Condition="Exists('$(MSBuildProjectDirectory)\runtimes\')" />

            <NativeFiles Include="$(MSBuildThisFileDirectory)..\runtimes\**\*"
                         Condition="!Exists('$(MSBuildProjectDirectory)\runtimes\') AND Exists('$(MSBuildThisFileDirectory)..\runtimes\')" />
        </ItemGroup>

        <Copy SourceFiles="@(NativeFiles)"
              DestinationFiles="@(NativeFiles->'$(OutputPath)runtimes\%(RecursiveDir)%(Filename)%(Extension)')"
              SkipUnchangedFiles="true"
              Condition="'@(NativeFiles)' != ''" />
    </Target>
</Project>