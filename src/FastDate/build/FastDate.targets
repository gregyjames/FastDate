<Project>
    <Target Name="CopyNativeLibraries" AfterTargets="Build">
        <ItemGroup>
            <NativeLibrary Include="$(MSBuildProjectDirectory)\runtimes\**\libfastdate.dylib" />
            <NativeLibrary Include="$(MSBuildProjectDirectory)\runtimes\**\libfastdate.so" />
            <NativeLibrary Include="$(MSBuildProjectDirectory)\runtimes\**\fastdate.dll" />
        </ItemGroup>

        <Copy SourceFiles="@(NativeLibrary)"
              DestinationFiles="@(NativeLibrary->'$(OutputPath)runtimes\%(RecursiveDir)%(Filename)%(Extension)')"
              SkipUnchangedFiles="true" />

        <Copy SourceFiles="@(NativeLibrary)"
              DestinationFolder="$(OutputPath)"
              SkipUnchangedFiles="true" />
    </Target>
</Project>