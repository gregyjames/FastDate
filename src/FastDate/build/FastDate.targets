<Project>
    <Target Name="CopyNativeLibraries" AfterTargets="Build">
        <ItemGroup>
            <!-- For NuGet package structure -->
            <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/osx-arm64/native/libfastdate.dylib"
                           Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/osx-arm64/native/libfastdate.dylib')" />
            <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/linux-x64/native/libfastdate.so"
                           Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/linux-x64/native/libfastdate.so')" />
            <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/win-x64/native/fastdate.dll"
                           Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/win-x64/native/fastdate.dll')" />
            <NativeLibrary Include="$(MSBuildThisFileDirectory)../runtimes/win-x86/native/fastdate.dll"
                           Condition="Exists('$(MSBuildThisFileDirectory)../runtimes/win-x86/native/fastdate.dll')" />
        </ItemGroup>
        <Copy SourceFiles="@(NativeLibrary)" DestinationFolder="$(OutputPath)" SkipUnchangedFiles="true" />
    </Target>
</Project>  